---
layout: null
---
[
  {% assign all_content = site.posts | concat: site.analyses %}
  {% for post in all_content %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "category": {{ post.category | default: "daily" | jsonify }},
    "severity": {{ post.severity | default: "" | jsonify }},
    "tags": {{ post.tags | default: "" | jsonify }},
    "description": {{ post.description | default: "" | jsonify }},
    "content": {{ post.content | strip_html | truncatewords: 200 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]